# -----------------------------------------------
# Lambda (Snowflake + API Key)
# -----------------------------------------------
SNOWFLAKE_ACCOUNT=xxxxx.us-west-2
SNOWFLAKE_USER=CLAUDE_HOOK_USER
# ローカル開発: 秘密鍵ファイルのパス（~/.snowflake/rsa_key.p8 など）
SNOWFLAKE_PRIVATE_KEY_PATH=~/.snowflake/rsa_key.p8
SNOWFLAKE_DATABASE=YOUR_DB
SNOWFLAKE_WAREHOUSE=COMPUTE_WH
SNOWFLAKE_SCHEMA=CLAUDE_CODE

# Lambda の x-api-key 認証キー（任意のランダム文字列）
API_KEY=your-random-api-key

# -----------------------------------------------
# Hook (Claude Code フック送信先)
# -----------------------------------------------
# sam local 起動時: http://host.docker.internal:3001/events
# 本番: デプロイ後の API Gateway URL
CLAUDE_CODE_HOOK_ENDPOINT=https://xxxxxxxxxx.execute-api.us-west-2.amazonaws.com/events
CLAUDE_CODE_HOOK_API_KEY=your-random-api-key
